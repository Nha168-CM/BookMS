@model List<BookMS.Models.CartItem>
@using BookMS.Models
@{ ViewData["Title"] = "Checkout"; Layout = "_LayoutCustomer"; }

<div class="container py-5">
    <h3 class="fw-bold mb-4"><i class="bi bi-bag-check me-2 text-primary"></i>Checkout</h3>

    <form asp-controller="CustomerOrder" asp-action="PlaceOrder" method="post">
        @Html.AntiForgeryToken()
        <div class="row g-4">
            <!-- Left: Delivery & Payment -->
            <div class="col-lg-7">
                <!-- Delivery Info -->
                <div class="card border-0 shadow-sm rounded-3 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-person-check me-2 text-primary"></i>Delivery Information</h5>
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label fw-semibold">Full Name</label>
                                <input type="text" class="form-control" value="@ViewBag.User?.FullName" readonly style="background:#f8fafc" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Email</label>
                                <input type="text" class="form-control" value="@ViewBag.User?.Email" readonly style="background:#f8fafc" />
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-semibold">Phone</label>
                                <input type="text" class="form-control" value="@ViewBag.User?.PhoneNumber" readonly style="background:#f8fafc" />
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Method -->
                <div class="card border-0 shadow-sm rounded-3 mb-4">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-credit-card me-2 text-primary"></i>Payment Method</h5>
                        <div class="row g-3">
                            <div class="col-4">
                                <div class="payment-label" data-value="0" style="cursor:pointer">
                                    <input type="radio" name="paymentMethod" value="0" class="d-none payment-radio" />
                                    <div class="payment-option text-center py-3 rounded-3 border">
                                        <i class="bi bi-cash fs-3 text-success d-block mb-1"></i>
                                        <span class="fw-semibold" style="font-size:0.85rem">Cash</span>
                                        <div class="text-muted" style="font-size:0.75rem">Pay on pickup</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="payment-label" data-value="1" style="cursor:pointer">
                                    <input type="radio" name="paymentMethod" value="1" class="d-none payment-radio" />
                                    <div class="payment-option text-center py-3 rounded-3 border">
                                        <i class="bi bi-credit-card fs-3 text-info d-block mb-1"></i>
                                        <span class="fw-semibold" style="font-size:0.85rem">Card</span>
                                        <div class="text-muted" style="font-size:0.75rem">Credit / Debit</div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-4">
                                <div class="payment-label" data-value="2" style="cursor:pointer">
                                    <input type="radio" name="paymentMethod" value="2" class="d-none payment-radio" />
                                    <div class="payment-option text-center py-3 rounded-3 border">
                                        <i class="bi bi-qr-code fs-3 text-warning d-block mb-1"></i>
                                        <span class="fw-semibold" style="font-size:0.85rem">QR Code</span>
                                        <div class="text-muted" style="font-size:0.75rem">KHQR / ABA</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Notes -->
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3"><i class="bi bi-chat-text me-2 text-primary"></i>Notes (Optional)</h5>
                        <textarea name="notes" class="form-control" rows="3"
                                  placeholder="Special requests or notes for your order..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Right: Order Summary -->
            <div class="col-lg-5">
                <div class="card border-0 shadow-sm rounded-3 position-sticky" style="top:80px">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-3">Order Summary</h5>

                        <!-- Items -->
                        <div style="max-height:280px;overflow-y:auto" class="mb-3">
                            @foreach (var item in Model)
                            {
                                <div class="d-flex gap-3 align-items-center mb-3">
                                    <div style="width:50px;height:60px;border-radius:6px;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:white;font-size:1.2rem;flex-shrink:0">
                                        <i class="bi bi-book"></i>
                                    </div>
                                    <div class="flex-fill min-width-0">
                                        <div class="fw-semibold text-truncate" style="font-size:0.875rem">@item.Book?.Title</div>
                                        <div class="text-muted" style="font-size:0.78rem">Qty: @item.Quantity</div>
                                    </div>
                                    <div class="fw-bold text-primary" style="font-size:0.875rem">
                                        $@((item.Book!.Price * item.Quantity).ToString("N2"))
                                    </div>
                                </div>
                            }
                        </div>

                        <hr />
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal</span>
                            <span class="fw-semibold">$@ViewBag.Total.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="text-muted">Shipping</span>
                            <span class="text-success fw-semibold">FREE</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-6">Total</span>
                            <span class="fw-bold fs-5 text-primary">$@ViewBag.Total.ToString("N2")</span>
                        </div>

                        <!-- Loyalty Points -->
                        <div class="alert alert-info py-2 mb-3" style="font-size:0.85rem">
                            <i class="bi bi-star me-1"></i>
                            You'll earn <strong>@Math.Floor((decimal)ViewBag.Total) points</strong> for this order!
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-bold fs-6">
                            <i class="bi bi-bag-check me-2"></i>Place Order
                        </button>
                        <a asp-controller="Cart" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            <i class="bi bi-arrow-left me-1"></i>Back to Cart
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
<script>
function selectPayment(value) {
    document.querySelectorAll('.payment-radio').forEach(r => {
        r.checked = false;
        r.nextElementSibling.style.borderColor = '#e2e8f0';
        r.nextElementSibling.style.background  = '#fff';
        r.nextElementSibling.style.boxShadow   = 'none';
    });
    const selected = document.querySelector('.payment-radio[value="' + value + '"]');
    if (selected) {
        selected.checked = true;
        selected.nextElementSibling.style.borderColor = '#4f46e5';
        selected.nextElementSibling.style.background  = '#eef2ff';
        selected.nextElementSibling.style.boxShadow   = '0 0 0 3px rgba(79,70,229,0.15)';
    }
}

document.querySelectorAll('.payment-label').forEach(label => {
    label.addEventListener('click', function(e) {
        e.preventDefault();
        selectPayment(this.dataset.value);
    });
});

selectPayment('0');
</script>
<style>
.payment-option { transition: border-color 0.2s, background 0.2s, box-shadow 0.2s; }
</style>
}
