@model List<BookMS.Models.CartItem>
@{ ViewData["Title"] = "My Cart"; Layout = "_LayoutCustomer"; }

<div class="container py-5">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h3 class="fw-bold mb-0"><i class="bi bi-cart3 me-2 text-primary"></i>My Cart
            <span class="badge bg-primary ms-2">@Model.Count items</span>
        </h3>
        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-arrow-left me-1"></i>Continue Shopping
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-cart-x text-muted" style="font-size:5rem"></i>
            <h5 class="text-muted mt-3">Your cart is empty</h5>
            <a asp-controller="Shop" asp-action="Index" class="btn btn-primary mt-3 px-4">
                <i class="bi bi-shop me-2"></i>Start Shopping
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <!-- Cart Items -->
            <div class="col-lg-8">
                @foreach (var item in Model)
                {
                    <div class="cart-item-card">
                        <div class="row align-items-center g-3">
                            <!-- Book Image -->
                            <div class="col-auto">
                                @if (!string.IsNullOrEmpty(item.Book?.ImageUrl))
                                {
                                    <img src="@item.Book.ImageUrl" style="width:80px;height:100px;object-fit:cover;border-radius:8px" alt="@item.Book.Title" />
                                }
                                else
                                {
                                    <div style="width:80px;height:100px;border-radius:8px;background:linear-gradient(135deg,#667eea,#764ba2);display:flex;align-items:center;justify-content:center;color:white;font-size:2rem">
                                        <i class="bi bi-book"></i>
                                    </div>
                                }
                            </div>
                            <!-- Book Info -->
                            <div class="col" style="min-width:0">
                                <span class="badge bg-light text-primary mb-1" style="font-size:0.7rem">@item.Book?.Category?.Name</span>
                                @{
                                    var cartTitle = item.Book?.Title ?? "";
                                    var cartTitleShort = cartTitle.Length > 40 ? cartTitle.Substring(0, 40) : cartTitle;
                                    var cartTitleTruncated = cartTitle.Length > 40;
                                    var cartAuthor = item.Book?.Author ?? "";
                                    var cartAuthorShort = cartAuthor.Length > 30 ? cartAuthor.Substring(0, 30) + "..." : cartAuthor;
                                }
                                <h6 class="fw-bold mb-1" style="line-height:1.3">
                                    <a asp-controller="Shop" asp-action="Details" asp-route-id="@item.BookId"
                                       class="text-decoration-none text-dark" title="@cartTitle">@cartTitleShort</a>@if (cartTitleTruncated){<a asp-controller="Shop" asp-action="Details" asp-route-id="@item.BookId" class="text-decoration-none text-primary ms-1" title="@cartTitle" style="font-size:0.78rem;font-weight:400">...more</a>}
                                </h6>
                                <p class="text-muted mb-0" style="font-size:0.85rem">by @cartAuthorShort</p>
                                <p class="text-primary fw-bold mb-0">$@item.Book?.Price.ToString("N2") each</p>
                            </div>
                            <!-- Qty Controls -->
                            <div class="col-auto">
                                <form asp-controller="Cart" asp-action="Update" method="post" class="d-flex align-items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@item.BookId" />
                                    <div class="d-flex align-items-center border rounded-3" style="overflow:hidden">
                                        <button type="submit" name="qty" value="@(item.Quantity - 1)"
                                                class="btn btn-sm px-2 border-0">−</button>
                                        <span class="px-3 fw-bold">@item.Quantity</span>
                                        <button type="submit" name="qty" value="@(item.Quantity + 1)"
                                                class="btn btn-sm px-2 border-0">+</button>
                                    </div>
                                </form>
                            </div>
                            <!-- Subtotal + Remove -->
                            <div class="col-auto text-end">
                                <div class="fw-bold text-primary fs-6">$@((item.Book!.Price * item.Quantity).ToString("N2"))</div>
                                <form asp-controller="Cart" asp-action="Remove" method="post" class="mt-1">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="bookId" value="@item.BookId" />
                                    <button type="submit" class="btn btn-sm btn-link text-danger p-0">
                                        <i class="bi bi-trash me-1"></i>Remove
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <!-- Order Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-3 position-sticky" style="top:80px">
                    <div class="card-body p-4">
                        <h5 class="fw-bold mb-4">Order Summary</h5>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Subtotal (@Model.Sum(i => i.Quantity) items)</span>
                            <span class="fw-semibold">$@ViewBag.Total.ToString("N2")</span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted">Shipping</span>
                            <span class="text-success fw-semibold">FREE</span>
                        </div>
                        <hr />
                        <div class="d-flex justify-content-between mb-4">
                            <span class="fw-bold fs-6">Total</span>
                            <span class="fw-bold fs-5 text-primary">$@ViewBag.Total.ToString("N2")</span>
                        </div>
                        <a asp-controller="CustomerOrder" asp-action="Checkout"
                           class="btn btn-primary w-100 py-2 fw-bold">
                            <i class="bi bi-bag-check me-2"></i>Proceed to Checkout
                        </a>
                        <a asp-controller="Shop" asp-action="Index" class="btn btn-outline-secondary w-100 mt-2">
                            Continue Shopping
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
