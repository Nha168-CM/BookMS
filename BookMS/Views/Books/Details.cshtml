@model Book
@{ ViewData["Title"] = "Book Details"; }

<div class="page-header">
    <div>
        <div class="page-title">Book Details</div>
        <div class="page-subtitle">@Model.Title</div>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary"><i class="bi bi-pencil me-2"></i>Edit</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-4">
        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <img src="@Model.ImageUrl" class="img-fluid rounded-3 shadow w-100" style="max-height:400px;object-fit:cover" alt="@Model.Title" />
        }
        else
        {
            <div class="d-flex align-items-center justify-content-center rounded-3 shadow"
                 style="height:300px;background:linear-gradient(135deg,#667eea,#764ba2);color:rgba(255,255,255,0.7);font-size:5rem">
                <i class="bi bi-book"></i>
            </div>
        }

        <div class="card mt-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">Price</span>
                    <span class="fs-4 fw-bold text-primary">$@Model.Price.ToString("N2")</span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <span class="text-muted">Stock</span>
                    <span class="stock-badge fs-6 @(Model.Stock == 0 ? "stock-empty" : Model.Stock <= 5 ? "stock-low" : "stock-ok")">
                        @Model.Stock units
                    </span>
                </div>
                <div class="d-flex justify-content-between align-items-center">
                    <span class="text-muted">Category</span>
                    <span class="badge bg-primary">@Model.Category?.Name</span>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-info-circle text-primary"></i> Book Information</div>
            <div class="card-body p-4">
                <dl class="row">
                    <dt class="col-4 text-muted">Title</dt>
                    <dd class="col-8 fw-semibold">@Model.Title</dd>
                    <dt class="col-4 text-muted">Author</dt>
                    <dd class="col-8">@Model.Author</dd>
                    <dt class="col-4 text-muted">ISBN</dt>
                    <dd class="col-8"><code>@Model.ISBN</code></dd>
                    <dt class="col-4 text-muted">Category</dt>
                    <dd class="col-8">@Model.Category?.Name</dd>
                    <dt class="col-4 text-muted">Added On</dt>
                    <dd class="col-8">@Model.CreatedAt.ToString("dd MMM yyyy")</dd>
                    <dt class="col-4 text-muted">Last Updated</dt>
                    <dd class="col-8">@Model.UpdatedAt.ToString("dd MMM yyyy")</dd>
                </dl>
                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <h6 class="text-muted mb-2">Description</h6>
                    <p class="mb-0">@Model.Description</p>
                }
            </div>
        </div>

        <div class="d-flex gap-3">
            <a asp-controller="Stock" asp-action="Create" class="btn btn-success">
                <i class="bi bi-box-arrow-in-down me-2"></i>Add Stock
            </a>
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post"
                  onsubmit="return confirm('Are you sure you want to delete this book?')">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-outline-danger">
                    <i class="bi bi-trash me-2"></i>Delete Book
                </button>
            </form>
        </div>
    </div>
</div>
