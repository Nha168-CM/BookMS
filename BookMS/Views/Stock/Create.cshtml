@model StockTransactionViewModel
@{ ViewData["Title"] = "Stock In / Out"; }

<div class="page-header">
    <div>
        <div class="page-title">Stock In / Out</div>
        <div class="page-subtitle">Record stock movement</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Back</a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-boxes text-primary"></i> Stock Transaction</div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3"></div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Transaction Type <span class="text-danger">*</span></label>
                        <div class="d-flex gap-3">
                            <label class="flex-fill">
                                <input type="radio" name="Type" value="0" class="d-none" checked />
                                <div class="card border-success stock-type-btn text-center py-3 active-green" style="cursor:pointer;border-width:2px!important">
                                    <i class="bi bi-arrow-down-circle-fill text-success fs-2"></i>
                                    <div class="fw-bold text-success mt-1">Stock In</div>
                                    <small class="text-muted">Add inventory</small>
                                </div>
                            </label>
                            <label class="flex-fill">
                                <input type="radio" name="Type" value="1" class="d-none" />
                                <div class="card border-danger stock-type-btn text-center py-3" style="cursor:pointer;border-width:2px!important;opacity:0.5">
                                    <i class="bi bi-arrow-up-circle-fill text-danger fs-2"></i>
                                    <div class="fw-bold text-danger mt-1">Stock Out</div>
                                    <small class="text-muted">Remove inventory</small>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="BookId" class="form-label">Book <span class="text-danger">*</span></label>
                        <select asp-for="BookId" class="form-select" onchange="updateStockInfo(this)">
                            <option value="">-- Select Book --</option>
                            @foreach (var b in Model.Books)
                            {
                                <option value="@b.Id" data-stock="@b.Stock" data-cat="@b.Category?.Name">
                                    @b.Title (@b.Category?.Name) — Stock: @b.Stock
                                </option>
                            }
                        </select>
                        <div id="stockInfo" class="mt-2" style="display:none">
                            <div class="alert alert-info py-2 mb-0">
                                <i class="bi bi-info-circle me-2"></i>
                                Category: <strong id="catName"></strong> |
                                Current Stock: <strong id="currentStock"></strong>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Quantity" class="form-label">Quantity <span class="text-danger">*</span></label>
                        <input asp-for="Quantity" class="form-control" type="number" min="1" placeholder="Enter quantity" />
                        <span asp-validation-for="Quantity" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Reference" class="form-label">Reference / PO Number</label>
                        <input asp-for="Reference" class="form-control" placeholder="e.g. PO-2024-001" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Notes" class="form-label">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="2" placeholder="Optional notes"></textarea>
                    </div>

                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="bi bi-check-lg me-2"></i>Save Transaction
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function updateStockInfo(sel) {
    const opt = sel.options[sel.selectedIndex];
    const info = document.getElementById('stockInfo');
    if (opt.value) {
        document.getElementById('catName').textContent = opt.dataset.cat || '-';
        document.getElementById('currentStock').textContent = opt.dataset.stock;
        info.style.display = 'block';
    } else {
        info.style.display = 'none';
    }
}

// Stock type toggle styling
document.querySelectorAll('input[name="Type"]').forEach((radio, i) => {
    radio.addEventListener('change', () => {
        document.querySelectorAll('.stock-type-btn').forEach((btn, j) => {
            btn.style.opacity = i === j ? '1' : '0.5';
        });
    });
});
</script>
}
