@model BookMS.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login"; Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login – BookStore</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <style>
        * { box-sizing: border-box; }
        html, body { margin: 0; padding: 0; overflow-x: hidden; }
        body { background: #0f172a; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 16px; }
        .auth-card { background: #fff; border-radius: 20px; padding: clamp(24px, 4vw, 40px); width: 100%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
        .auth-logo { background: #4f46e5; color: #fff; width: 56px; height: 56px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 1.6rem; margin: 0 auto 16px; }
        .form-control:focus { border-color: #4f46e5; box-shadow: 0 0 0 3px rgba(79,70,229,0.15); }
        .btn-primary { background: #4f46e5; border: none; }
        .btn-primary:hover { background: #4338ca; }
        .tab-btn { flex: 1; padding: 10px; border: 1px solid #e2e8f0; background: #f8fafc; border-radius: 10px; font-size: 0.875rem; font-weight: 600; color: #64748b; cursor: pointer; transition: all 0.2s; }
        .tab-btn.active { background: #4f46e5; border-color: #4f46e5; color: #fff; }
        .input-icon { position: relative; }
        .input-icon i { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: #94a3b8; }
        .input-icon input { padding-left: 38px; }
        
    </style>
</head>
<body>
    <div class="auth-card">
        <div class="auth-logo"><i class="bi bi-book-half"></i></div>
        <h4 class="text-center fw-bold mb-1">Welcome Back</h4>
        <p class="text-center text-muted mb-4" style="font-size:0.875rem">Sign in to your BookStore account</p>

        <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-3" style="font-size:0.85rem"></div>

        <form asp-action="Login" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label fw-semibold" style="font-size:0.875rem">Email or Phone Number</label>
                <div class="input-icon">
                    <i class="bi bi-person"></i>
                    <input asp-for="EmailOrPhone" class="form-control" placeholder="email@example.com or 0123456789" autocomplete="username" />
                </div>
                <span asp-validation-for="EmailOrPhone" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label class="form-label fw-semibold" style="font-size:0.875rem">Password</label>
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" class="form-control" placeholder="Your password" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-4">
                <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                <label class="form-check-label" style="font-size:0.875rem">Keep me signed in</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
            </button>
        </form>

        <hr class="my-4" />
        <a asp-action="GoogleLogin" asp-route-returnUrl="@ViewBag.ReturnUrl"
           class="btn btn-outline-secondary w-100 py-2 d-flex align-items-center justify-content-center gap-2 mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 48 48">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.31-8.16 2.31-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
            Continue with Google
        </a>
        <p class="text-center mb-0" style="font-size:0.875rem">
            Don't have an account?
            <a asp-action="Register" asp-route-returnUrl="@ViewBag.ReturnUrl" class="fw-bold text-decoration-none" style="color:#4f46e5">Create Account</a>
        </p>
        <p class="text-center mt-2 mb-0" style="font-size:0.875rem">
            <a asp-controller="Shop" asp-action="Index" class="text-muted text-decoration-none">
                <i class="bi bi-arrow-left me-1"></i>Continue browsing shop
            </a>
        </p>
    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
</body>
</html>
