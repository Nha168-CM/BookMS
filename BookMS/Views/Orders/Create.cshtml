@{ ViewData["Title"] = "New Sale"; }
@{
    var books = ViewBag.Books as List<Book> ?? new List<Book>();
}

<div class="page-header no-print">
    <div>
        <div class="page-title">New Sale</div>
        <div class="page-subtitle">Create a new sales order</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-2"></i>Orders</a>
</div>

<form asp-action="Create" method="post" id="orderForm">
    @Html.AntiForgeryToken()
    <div class="pos-layout">
        <!-- Left: Book Selection -->
        <div>
            <!-- Search -->
            <div class="card mb-3">
                <div class="card-body py-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="bookSearch" class="form-control" placeholder="Search books..." />
                    </div>
                </div>
            </div>

            <!-- Book List -->
            <div class="row g-3" id="bookGrid">
                @foreach (var book in books)
                {
                    <div class="col-md-6 book-item" data-title="@book.Title.ToLower()" data-author="@book.Author.ToLower()">
                        <div class="card book-select-card" style="cursor:pointer;transition:all 0.2s"
                             onclick="addToCart(@book.Id, '@book.Title.Replace("'","\\'")', @book.Price, @book.Stock)"
                             data-id="@book.Id">
                            <div class="card-body p-3">
                                <div class="d-flex gap-3 align-items-center">
                                    <!-- Book cover -->
                                    @if (!string.IsNullOrEmpty(book.ImageUrl) && (book.ImageUrl.StartsWith("http") || book.ImageUrl.StartsWith("/")))
                                    {
                                        <div style="width:48px;height:64px;flex-shrink:0;border-radius:6px;overflow:hidden">
                                            <img src="@book.ImageUrl"
                                                 style="width:100%;height:100%;object-fit:cover"
                                                 onerror="this.parentElement.innerHTML='<div style=\'width:48px;height:64px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:6px;display:flex;align-items:center;justify-content:center;color:white;font-size:1.3rem\'><i class=\'bi bi-book\'></i></div>'"
                                                 alt="@book.Title" />
                                        </div>
                                    }
                                    else
                                    {
                                        <div style="width:48px;height:64px;background:linear-gradient(135deg,#667eea,#764ba2);border-radius:6px;display:flex;align-items:center;justify-content:center;color:white;font-size:1.3rem;flex-shrink:0">
                                            <i class="bi bi-book"></i>
                                        </div>
                                    }
                                    <div style="flex:1;min-width:0;overflow:hidden">
                                        <div class="fw-bold" style="font-size:0.82rem;overflow:hidden;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;line-height:1.3">@book.Title</div>
                                        <div class="text-muted text-truncate" style="font-size:0.75rem">@book.Author</div>
                                        <div class="d-flex justify-content-between align-items-center mt-1" style="gap:4px">
                                            <span class="text-primary fw-bold" style="font-size:0.82rem;white-space:nowrap">$@book.Price.ToString("N2")</span>
                                            <span class="stock-badge @(book.Stock <= 5 ? "stock-low" : "stock-ok")" style="white-space:nowrap;font-size:0.7rem">@book.Stock left</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Right: Cart & Summary -->
        <div>
            <div class="pos-summary">
                <div class="card-header"><i class="bi bi-cart3 text-primary"></i> Cart</div>

                <!-- Cart Items -->
                <div id="cartItems" style="min-height:120px;max-height:300px;overflow-y:auto">
                    <div id="emptyCart" class="text-center text-muted py-4">
                        <i class="bi bi-cart-x fs-2 d-block mb-2"></i>No items added
                    </div>
                </div>

                <div class="p-3 border-top">
                    <!-- Customer Info -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Customer Name</label>
                        <input type="text" name="CustomerName" class="form-control form-control-sm" placeholder="Walk-in customer" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Phone</label>
                        <input type="text" name="CustomerPhone" class="form-control form-control-sm" placeholder="Optional" />
                    </div>

                    <!-- ✅ Fix: Payment Method buttons - ប្រើ grid 3 columns ជំនួស flex -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Payment Method</label>
                        <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px">
                            <label>
                                <input type="radio" name="PaymentMethod" value="0" class="d-none" checked />
                                <div class="payment-btn active" data-val="0" style="border:2px solid #10b981;border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;font-size:0.8rem;font-weight:600;color:#10b981;background:#fff;transition:all 0.2s">
                                    <i class="bi bi-cash d-block mb-1" style="font-size:1.1rem"></i>Cash
                                </div>
                            </label>
                            <label>
                                <input type="radio" name="PaymentMethod" value="1" class="d-none" />
                                <div class="payment-btn" data-val="1" style="border:2px solid #06b6d4;border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;font-size:0.8rem;font-weight:600;color:#06b6d4;background:#fff;transition:all 0.2s">
                                    <i class="bi bi-credit-card d-block mb-1" style="font-size:1.1rem"></i>Card
                                </div>
                            </label>
                            <label>
                                <input type="radio" name="PaymentMethod" value="2" class="d-none" />
                                <div class="payment-btn" data-val="2" style="border:2px solid #f59e0b;border-radius:8px;padding:8px 4px;text-align:center;cursor:pointer;font-size:0.8rem;font-weight:600;color:#f59e0b;background:#fff;transition:all 0.2s">
                                    <i class="bi bi-qr-code d-block mb-1" style="font-size:1.1rem"></i>QR
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Totals -->
                    <div class="bg-light rounded p-3 mb-3">
                        <div class="d-flex justify-content-between mb-1">
                            <span class="text-muted">Subtotal</span>
                            <strong id="subtotalDisplay">$0.00</strong>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="text-muted">Discount</span>
                            <div class="input-group input-group-sm" style="width:120px">
                                <span class="input-group-text">$</span>
                                <input type="number" name="Discount" id="discountInput" class="form-control" value="0" min="0" step="0.01" oninput="updateTotals()" />
                            </div>
                        </div>
                        <hr class="my-2" />
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold">Total</span>
                            <span class="fw-bold text-primary fs-5" id="totalDisplay">$0.00</span>
                        </div>
                    </div>

                    <!-- Amount Paid -->
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Amount Paid</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input type="number" name="AmountPaid" id="amountPaidInput" class="form-control" value="0" min="0" step="0.01" oninput="updateChange()" />
                        </div>
                        <div class="d-flex justify-content-between mt-2 px-1">
                            <span class="text-muted">Change</span>
                            <strong id="changeDisplay" class="text-success">$0.00</strong>
                        </div>
                    </div>

                    <!-- Hidden inputs for cart -->
                    <div id="cartInputs"></div>

                    <button type="submit" class="btn btn-primary w-100" id="submitBtn" disabled>
                        <i class="bi bi-bag-check me-2"></i>Complete Sale
                    </button>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {
<script>
let cart = {};
let bookStock = {};

@foreach (var book in books)
{
    <text>bookStock[@book.Id] = @book.Stock;</text>
}

function addToCart(id, title, price, stock) {
    if (cart[id]) {
        if (cart[id].qty >= stock) { alert('Not enough stock!'); return; }
        cart[id].qty++;
    } else {
        cart[id] = { id, title, price, qty: 1, stock };
    }
    renderCart();
}

function removeFromCart(id) {
    delete cart[id];
    renderCart();
}

function changeQty(id, delta) {
    if (!cart[id]) return;
    cart[id].qty += delta;
    if (cart[id].qty <= 0) { removeFromCart(id); return; }
    if (cart[id].qty > cart[id].stock) { cart[id].qty = cart[id].stock; alert('Max stock reached!'); }
    renderCart();
}

function renderCart() {
    const container = document.getElementById('cartItems');
    const inputs = document.getElementById('cartInputs');
    const items = Object.values(cart);

    if (items.length === 0) {
        container.innerHTML = '<div id="emptyCart" class="text-center text-muted py-4"><i class="bi bi-cart-x fs-2 d-block mb-2"></i>No items added</div>';
        inputs.innerHTML = '';
        document.getElementById('submitBtn').disabled = true;
        updateTotals();
        return;
    }

    container.innerHTML = items.map((item, i) => `
        <div class="cart-item">
            <div class="flex-fill">
                <div style="font-size:0.82rem;font-weight:600">${item.title}</div>
                <div style="font-size:0.75rem;color:#64748b">$${item.price.toFixed(2)} each</div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <button type="button" onclick="changeQty(${item.id},-1)" class="btn btn-sm btn-outline-secondary" style="width:28px;height:28px;padding:0">-</button>
                <span class="fw-bold">${item.qty}</span>
                <button type="button" onclick="changeQty(${item.id},1)" class="btn btn-sm btn-outline-secondary" style="width:28px;height:28px;padding:0">+</button>
                <span style="min-width:60px;text-align:right;font-weight:700">$${(item.price * item.qty).toFixed(2)}</span>
                <button type="button" onclick="removeFromCart(${item.id})" class="btn btn-sm btn-outline-danger" style="width:28px;height:28px;padding:0"><i class="bi bi-x"></i></button>
            </div>
        </div>
    `).join('');

    inputs.innerHTML = items.map((item, i) => `
        <input type="hidden" name="Items[${i}].BookId" value="${item.id}" />
        <input type="hidden" name="Items[${i}].Quantity" value="${item.qty}" />
        <input type="hidden" name="Items[${i}].UnitPrice" value="${item.price}" />
        <input type="hidden" name="Items[${i}].Discount" value="0" />
    `).join('');

    document.getElementById('submitBtn').disabled = false;
    updateTotals();
}

function updateTotals() {
    const subtotal = Object.values(cart).reduce((s, i) => s + i.price * i.qty, 0);
    const discount = parseFloat(document.getElementById('discountInput').value) || 0;
    const total = Math.max(0, subtotal - discount);
    document.getElementById('subtotalDisplay').textContent = '$' + subtotal.toFixed(2);
    document.getElementById('totalDisplay').textContent = '$' + total.toFixed(2);
    updateChange();
}

function updateChange() {
    const discount = parseFloat(document.getElementById('discountInput').value) || 0;
    const subtotal = Object.values(cart).reduce((s, i) => s + i.price * i.qty, 0);
    const total = Math.max(0, subtotal - discount);
    const paid = parseFloat(document.getElementById('amountPaidInput').value) || 0;
    const change = paid - total;
    const el = document.getElementById('changeDisplay');
    el.textContent = '$' + Math.max(0, change).toFixed(2);
    el.className = change >= 0 ? 'text-success fw-bold' : 'text-danger fw-bold';
}

document.getElementById('bookSearch').addEventListener('input', function() {
    const q = this.value.toLowerCase();
    document.querySelectorAll('.book-item').forEach(el => {
        const match = el.dataset.title.includes(q) || el.dataset.author.includes(q);
        el.style.display = match ? '' : 'none';
    });
});

// Payment buttons
document.querySelectorAll('.payment-btn').forEach(btn => {
    btn.addEventListener('click', () => {
        document.querySelectorAll('.payment-btn').forEach(b => {
            b.style.background = '#fff';
            b.style.opacity = '0.7';
        });
        btn.style.background = '#f8f9ff';
        btn.style.opacity = '1';
    });
});
</script>
<style>
.book-select-card:hover { border-color: #4f46e5 !important; background: #eef2ff; }
.payment-btn:hover { opacity: 0.85; }
</style>
}
