@using BookMS.Models
@using Microsoft.AspNetCore.Identity
@inject UserManager<AppUser> UserManager
@{
    var currentUser = User.Identity?.IsAuthenticated == true
        ? await UserManager.GetUserAsync(User)
        : null;
    string? navProfileImage = currentUser?.ProfileImage;
    string navInitial = currentUser?.FullName?.Length > 0
        ? currentUser.FullName.Substring(0, 1).ToUpper()
        : (User.Identity?.Name?[0].ToString().ToUpper() ?? "?");
    // Read CartCount from HttpContext.Items (set by middleware in Program.cs)
    int navCartCount = Context.Items.TryGetValue("CartCount", out var cc) && cc is int c ? c : 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BookStore</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root {
            --primary: #4f46e5; --primary-dark: #4338ca;
            --accent: #06b6d4; --bg: #f8fafc;
            --dark: #1e293b; --muted: #64748b;
            --border: #e2e8f0; --card: #ffffff;
        }
        body { background: var(--bg); font-family: 'Segoe UI', system-ui, sans-serif; overflow-x: hidden; }
        html { overflow-x: hidden; }
        /* Navbar */
        .shop-nav { background: var(--dark); padding: 0; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,0.2); }
        .shop-nav .navbar-brand { color: #fff !important; font-weight: 800; font-size: 1.3rem; }
        .shop-nav .nav-link { color: rgba(255,255,255,0.8) !important; transition: color 0.2s; padding: 1.1rem 1rem; }
        .shop-nav .nav-link:hover, .shop-nav .nav-link.active { color: #fff !important; }
        .cart-badge { background: var(--primary); color: #fff; border-radius: 50%; padding: 1px 6px; font-size: 0.7rem; font-weight: 700; }
        /* Book Cards */
        .book-card { border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: transform 0.2s, box-shadow 0.2s; background: var(--card); height: 100%; display: flex; flex-direction: column; }
        .book-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.1); }
        .book-cover { height: 220px; object-fit: cover; width: 100%; }
        .book-cover-placeholder { height: 220px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.6); font-size: 3.5rem; }
        .book-price { color: var(--primary); font-weight: 800; font-size: 1.1rem; }
        .btn-cart { background: var(--primary); color: #fff; border: none; border-radius: 8px; padding: 8px 16px; font-weight: 600; font-size: 0.85rem; transition: background 0.2s; }
        .btn-cart:hover { background: var(--primary-dark); color: #fff; }
        .btn-wishlist { background: transparent; border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; color: var(--muted); transition: all 0.2s; }
        .btn-wishlist:hover { border-color: #ef4444; color: #ef4444; }
        /* Category Pills */
        .cat-pill { padding: 6px 14px; border-radius: 20px; background: #fff; border: 1px solid var(--border); color: var(--dark); font-size: 0.85rem; cursor: pointer; transition: all 0.2s; text-decoration: none; }
        .cat-pill:hover, .cat-pill.active { background: var(--primary); border-color: var(--primary); color: #fff; }
        /* Cart */
        .cart-item-card { background: var(--card); border: 1px solid var(--border); border-radius: 12px; padding: 16px; margin-bottom: 12px; }
        .qty-btn { width: 32px; height: 32px; border-radius: 6px; border: 1px solid var(--border); background: #fff; display: flex; align-items: center; justify-content: center; cursor: pointer; }
        /* Order Status */
        .status-pending { background: #fef3c7; color: #d97706; padding: 3px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
        .status-completed { background: #d1fae5; color: #059669; padding: 3px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
        .status-cancelled { background: #fee2e2; color: #dc2626; padding: 3px 10px; border-radius: 20px; font-size: 0.78rem; font-weight: 600; }
        /* Loyalty */
        .loyalty-card { background: linear-gradient(135deg, #4f46e5 0%, #06b6d4 100%); color: #fff; border-radius: 16px; padding: 20px; }
        /* Footer */
        .shop-footer { background: var(--dark); color: rgba(255,255,255,0.7); padding: 40px 0 20px; margin-top: 60px; }
        /* Nav Avatar */
        .nav-avatar { width:32px; height:32px; border-radius:50%; overflow:hidden; background:var(--primary); display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:0.8rem; flex-shrink:0; }
        .nav-avatar img { width:100%; height:100%; object-fit:cover; }
    </style>
</head>
<body>
    <!-- Navbar -->
    <nav class="shop-nav navbar navbar-expand-lg">
        <div class="container">
            <a class="navbar-brand" asp-controller="Shop" asp-action="Index">
                <i class="bi bi-book-half me-2"></i>BookStore
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#shopNav">
                <i class="bi bi-list text-white fs-4"></i>
            </button>
            <div class="collapse navbar-collapse" id="shopNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a asp-controller="Shop" asp-action="Index"
                           class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Shop" ? "active" : "")">
                            <i class="bi bi-shop me-1"></i>Shop
                        </a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center gap-2">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a asp-controller="Cart" asp-action="Index" class="nav-link" style="position:relative; padding-right: 18px;">
                                <i class="bi bi-cart3 fs-5"></i>
                                @if (navCartCount > 0)
                                {
                                    <span class="cart-badge" style="position:absolute; top:6px; right:-4px; min-width:18px; text-align:center; line-height:18px; height:18px; padding:0 5px; font-size:0.65rem;">@navCartCount</span>
                                }
                            </a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
                                <div class="nav-avatar">
                                    @if (!string.IsNullOrEmpty(navProfileImage))
                                    {
                                        <img src="@(navProfileImage.StartsWith("/") ? navProfileImage : "/" + navProfileImage)" alt="avatar" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                                        <span style="display:none">@navInitial</span>
                                    }
                                    else
                                    {
                                        @navInitial
                                    }
                                </div>
                                @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow">
                                <li><a class="dropdown-item" asp-controller="CustomerOrder" asp-action="Index"><i class="bi bi-bag me-2"></i>My Orders</a></li>
                                <li><a class="dropdown-item" asp-controller="Users" asp-action="Profile"><i class="bi bi-person me-2"></i>Profile</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Logout</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a asp-controller="Auth" asp-action="Login" class="nav-link"><i class="bi bi-box-arrow-in-right me-1"></i>Login</a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Auth" asp-action="Register" class="btn btn-primary btn-sm px-3">Register</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    @* ✅ Fix: Only render container when alert message actually exists — prevents empty gap *@
    @if (TempData["Success"] != null || TempData["Error"] != null || TempData["Info"] != null)
    {
        <div class="container mt-3">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle me-2"></i>@TempData["Success"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info alert-dismissible fade show"><i class="bi bi-info-circle me-2"></i>@TempData["Info"]<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
            }
        </div>
    }

    @RenderBody()

    <!-- Footer -->
    <footer class="shop-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-md-4">
                    <h5 class="text-white mb-3"><i class="bi bi-book-half me-2"></i>BookStore</h5>
                    <p style="font-size:0.875rem">Your trusted book store in Phnom Penh. Find your next favorite book today.</p>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Quick Links</h6>
                    <ul class="list-unstyled" style="font-size:0.875rem">
                        <li><a asp-controller="Shop" asp-action="Index" class="text-decoration-none" style="color:inherit">Shop</a></li>
                        <li><a asp-controller="Auth" asp-action="Login" class="text-decoration-none" style="color:inherit">Login</a></li>
                        <li><a asp-controller="Auth" asp-action="Register" class="text-decoration-none" style="color:inherit">Register</a></li>
                    </ul>
                </div>
                <div class="col-md-4">
                    <h6 class="text-white mb-3">Contact</h6>
                    <p style="font-size:0.875rem"><i class="bi bi-geo-alt me-2"></i>Phnom Penh, Cambodia</p>
                    <p style="font-size:0.875rem"><i class="bi bi-telephone me-2"></i>+855 12 345 678</p>
                </div>
            </div>
            <hr style="border-color:rgba(255,255,255,0.1)" class="mt-4" />
            <p class="text-center mb-0" style="font-size:0.8rem">© 2025 BookStore. All rights reserved.</p>
        </div>
    </footer>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/bootstrap/5.3.2/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
